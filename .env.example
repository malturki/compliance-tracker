TURSO_DATABASE_URL=libsql://[your-db].turso.io
TURSO_AUTH_TOKEN=your-token-here

# Vercel Blob Storage (for evidence file attachments)
BLOB_READ_WRITE_TOKEN=placeholder-token-will-set-in-vercel

# Email Configuration (for alerts and digests)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
ALERT_EMAIL_FROM=noreply@yourcompany.com
ALERT_EMAIL_TO=compliance@yourcompany.com

# Cron Job Protection
CRON_SECRET=your-random-secret-here

# Public App URL (for email links)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
