{
  "permissions": {
    "defaultMode": "plan",
    "allow": [
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log --*)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(cat *)",
      "Bash(sed *)",
      "Bash(grep *)",
      "Bash(npm run dev)",
      "Bash(npm run build)",
      "Bash(npm test -- --run)",
      "Bash(npm test -- --run *)",
      "Bash(npx vitest *)",
      "Bash(npm run seed)",
      "Bash(npm run db:push)",
      "Bash(npm run db:studio)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push *)"
    ]
  }
}
