TURSO_DATABASE_URL=file:./compliance.db
TURSO_AUTH_TOKEN=not-needed-for-local

# Email Configuration (dev placeholders - configure for testing)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-dev-email@gmail.com
# SMTP_PASS=your-app-password
# ALERT_EMAIL_FROM=dev@localhost
# ALERT_EMAIL_TO=test@localhost

# Cron Job Protection (dev)
# CRON_SECRET=dev-secret-change-in-production

# Public App URL (dev)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OpenAI API Key (optional - leave commented for fallback summaries)
# OPENAI_API_KEY=sk-your-openai-api-key-here
